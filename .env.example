# Настройки Beget для деплоя
# Скопируй этот файл в .env и заполни своими данными
# .env НЕ попадает в git

# SSH / SFTP логин (обычно совпадает с именем аккаунта на Бегете)
BEGET_USER=your_login

# SSH-хост Бегета — смотри в панели управления → SSH/FTP
# Обычно формат: your_login.beget.tech или s123.beget.com
BEGET_HOST=your_login.beget.tech

# Путь на сервере до папки сайта
# Формат: /home/your_login/domain.ru/public_html
BEGET_PATH=/home/your_login/domain.ru/public_html

# Домен для отображения после деплоя (необязательно)
DOMAIN=domain.ru

# Telegram Bot токен — Южнобережный (@ryukzak_yub_bot)
TG_BOT_TOKEN=1234567890:your_token_here

# Telegram Bot токен — Beauty Визитка (@beauty_vizitka_bot)
BEAUTY_BOT_TOKEN=1234567890:your_token_here

# ── Supabase (Beauty TMA backend) ──────────────────────────
# Project URL — Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publishable key (раньше назывался anon / public)
# Supabase Dashboard → Project Settings → API → Publishable key
# БЕЗОПАСНО коммитить в код приложения — защищён политиками RLS
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Secret key (раньше назывался service_role)
# Supabase Dashboard → Project Settings → API → Secret keys
# СЕКРЕТ — никогда не коммитить, не пересылать, не выкладывать
# Обходит RLS, даёт полный доступ к базе
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Connection string для прямого подключения к Postgres
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Вид: postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# PASSWORD — тот, что ты задала при создании проекта
SUPABASE_DB_URL=postgresql://postgres.xxxxx:your_db_password@aws-0-xxx.pooler.supabase.com:6543/postgres
