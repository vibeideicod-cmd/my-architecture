# Настройки Beget для деплоя
# Скопируй этот файл в .env и заполни своими данными
# .env НЕ попадает в git

# SSH / SFTP логин (обычно совпадает с именем аккаунта на Бегете)
BEGET_USER=your_login

# SSH-хост Бегета — смотри в панели управления → SSH/FTP
# Обычно формат: your_login.beget.tech или s123.beget.com
BEGET_HOST=your_login.beget.tech

# Путь на сервере до папки сайта
# Формат: /home/your_login/domain.ru/public_html
BEGET_PATH=/home/your_login/domain.ru/public_html

# Домен для отображения после деплоя (необязательно)
DOMAIN=domain.ru

# Telegram Bot токен — Южнобережный (@ryukzak_yub_bot)
TG_BOT_TOKEN=1234567890:your_token_here

# Telegram Bot токен — Beauty Визитка (@beauty_vizitka_bot)
BEAUTY_BOT_TOKEN=1234567890:your_token_here
