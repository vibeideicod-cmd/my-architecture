# ============================================================
# TG-бот календаря Ирины — пример .env (РФ-стек, 152-ФЗ)
# Скопируй в .env (рядом) и заполни. Файл .env в гит НЕ коммитится.
# ============================================================

# --- Telegram ---

# Токен бота от @BotFather (формат 123456:AABBCC...)
TG_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Telegram User ID Ирины (узнать через @userinfobot — пишет числом)
TG_OWNER_CHAT_ID=PUT_IRINA_TG_USER_ID

# Ссылка на Mini App (фронт-файл, который пишет Кодыч)
# Пример: https://demo.ideidlyabiznesa1913.ru/cal/
MINIAPP_URL=https://demo.ideidlyabiznesa1913.ru/cal/

# Ссылка на политику конфиденциальности (нужна для команды /privacy в боте)
# Пример: https://demo.ideidlyabiznesa1913.ru/cal/legal/privacy.html
PRIVACY_URL=https://demo.ideidlyabiznesa1913.ru/cal/legal/privacy.html

# Порт, на котором слушает endpoint /notify (за nginx-прокси)
PORT=3010

# Общий секрет, которым подписываются внутренние вызовы между ботами
# и опциональный Baserow webhook. Сгенерируй: openssl rand -hex 32
NOTIFY_SECRET=PUT_RANDOM_64_HEX_HERE

# Адрес email-сервиса (локально на VPS)
EMAIL_NOTIFY_URL=http://127.0.0.1:3012/notify

# Адрес VK-бота (опционально, если запустим VK-канал)
VK_BOT_NOTIFY_URL=http://127.0.0.1:3011/notify

# --- Baserow (РФ, ст.18 ч.5 152-ФЗ) ---

# URL Baserow на VPS Cheerful Marik. Уточнит Инна (её Baserow).
# Пример: https://baserow.cheerful-marik.ru
BASEROW_URL=https://baserow.<host>

# API-токен Baserow (см. BASEROW-SETUP.md, шаг 4). Permissions: Read+Create+Update.
BASEROW_TOKEN=PUT_BASEROW_TOKEN_HERE

# Числовой ID таблицы bookings (см. BASEROW-SETUP.md, шаг 5)
BASEROW_TABLE_BOOKINGS=0

# Интервал опроса Baserow на новые записи (резерв на случай если webhook не работает)
POLL_INTERVAL_SEC=60
