# ============================================================
# VK-бот календаря Ирины — пример .env
# ============================================================

# Токен сообщества VK (в настройках группы → «Работа с API» → Ключи доступа)
# Нужны права: messages, manage
VK_GROUP_TOKEN=PUT_VK_GROUP_TOKEN

# Числовой ID группы (без знака минус). Пример: 123456789
VK_GROUP_ID=PUT_VK_GROUP_ID

# Числовой ID Ирины во ВКонтакте (узнать на vk.com/id0 — у себя в адресной строке)
VK_OWNER_USER_ID=PUT_IRINA_VK_USER_ID

# Ссылка на VK Mini App (после публикации в vk.com/dev → MyApps)
# Пример: https://vk.com/app51234567
VK_MINIAPP_URL=https://vk.com/app00000000

# Порт (за nginx-прокси либо локально для cross-talk с tg-bot)
PORT=3011

# Тот же секрет, что и у TG-бота — для приёма /notify от tg-bot
NOTIFY_SECRET=PUT_RANDOM_64_HEX_HERE

# Confirmation-token для VK Callback API (выдаёт VK при настройке Callback)
VK_CONFIRMATION_TOKEN=PUT_VK_CONFIRMATION_TOKEN

# Secret-key из настроек Callback (любая строка, та же что в VK)
VK_CALLBACK_SECRET=PUT_VK_CALLBACK_SECRET
