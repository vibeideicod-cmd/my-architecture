#!/bin/bash
# deploy-client.sh.example — ШАБЛОН для деплоя нового клиента
#
# КАК ИСПОЛЬЗОВАТЬ:
# 1. Скопируй этот файл: cp deploy-client.sh.example deploy-{код}.sh
# 2. Заполни две переменные ниже (CLIENT_CODE и LOCAL_PATH)
# 3. Запусти: ./deploy-{код}.sh
#
# Результат: demo.ideidlyabiznesa1913.ru/{CLIENT_CODE}/
#
# Субдомен demo. создаётся один раз — больше в Beget заходить не нужно.

set -e

# ─── ЗАПОЛНИ ДВЕ СТРОКИ ───────────────────────────────────────────────
CLIENT_CODE="yub"                          # Код клиента (латиница, без пробелов)
LOCAL_PATH="clients/yuzhnoberezhniy/mvp"   # Папка с HTML-файлами клиента
# ──────────────────────────────────────────────────────────────────────

if [ -f .env ]; then
  export $(grep -v '^#' .env | xargs)
else
  echo "❌ Файл .env не найден."
  exit 1
fi

: "${BEGET_USER:?❌ Укажи BEGET_USER в .env}"
: "${BEGET_HOST:?❌ Укажи BEGET_HOST в .env}"

DEMO_PATH="/home/icepaeqw/demo.ideidlyabiznesa1913.ru/public_html"

echo "🚀 Деплой [${CLIENT_CODE}] → demo.ideidlyabiznesa1913.ru/${CLIENT_CODE}/"

# Создать папку клиента если её нет
ssh "${BEGET_USER}@${BEGET_HOST}" "mkdir -p ${DEMO_PATH}/${CLIENT_CODE}"

# Скопировать все HTML-файлы
scp "${LOCAL_PATH}"/*.html "${BEGET_USER}@${BEGET_HOST}:${DEMO_PATH}/${CLIENT_CODE}/"

echo "✅ https://demo.ideidlyabiznesa1913.ru/${CLIENT_CODE}/"
