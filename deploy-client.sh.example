#!/bin/bash
# deploy-client.sh.example — ШАБЛОН для деплоя нового клиента
#
# КАК ИСПОЛЬЗОВАТЬ:
# 1. Скопируй: cp deploy-client.sh.example deploy-{код}.sh
# 2. Заполни две переменные ниже
# 3. Запусти: ./deploy-{код}.sh
#
# Результат: ideidlyabiznesa1913.ru/demo/{CLIENT_CODE}/
# В Beget больше ничего не нужно создавать.

set -e

# ─── ЗАПОЛНИ ДВЕ СТРОКИ ───────────────────────────────────────────────
CLIENT_CODE="yub"                          # Код клиента (латиница, без пробелов)
LOCAL_PATH="clients/yuzhnoberezhniy/mvp"   # Папка с HTML-файлами клиента
# ──────────────────────────────────────────────────────────────────────

if [ -f .env ]; then
  export $(grep -v '^#' .env | xargs)
else
  echo "❌ Файл .env не найден."
  exit 1
fi

: "${BEGET_USER:?❌ Укажи BEGET_USER в .env}"
: "${BEGET_HOST:?❌ Укажи BEGET_HOST в .env}"

DEMO_PATH="~/demo"

echo "🚀 Деплой [${CLIENT_CODE}] → ideidlyabiznesa1913.ru/demo/${CLIENT_CODE}/"

ssh "${BEGET_USER}@${BEGET_HOST}" "mkdir -p ${DEMO_PATH}/${CLIENT_CODE}"
scp "${LOCAL_PATH}"/*.html "${BEGET_USER}@${BEGET_HOST}:${DEMO_PATH}/${CLIENT_CODE}/"

echo "✅ https://ideidlyabiznesa1913.ru/demo/${CLIENT_CODE}/"
