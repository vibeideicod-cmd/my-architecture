# ============================================================
# Email-уведомления (РФ, ст.18 ч.5 152-ФЗ) — пример .env
# ============================================================

# --- Выбор провайдера ---
# unisender (по умолчанию, проще, 1500 писем/мес бесплатно)
# sendpulse (12000 писем/мес бесплатно, OAuth2)
EMAIL_PROVIDER=unisender

# --- Получатель и отправитель ---

# Email Ирины (куда падают уведомления)
IRINA_EMAIL=her_email@example.com
IRINA_NAME=Ирина

# Адрес отправителя — должен быть подтверждён в кабинете провайдера
# (или на верифицированном домене Ирины, когда он появится).
FROM_EMAIL=hello@<домен-ирины>
FROM_NAME=Календарь Ирины

# --- HTTP / общий секрет ---

PORT=3012
NOTIFY_SECRET=PUT_RANDOM_64_HEX_HERE

# --- UniSender Go (если EMAIL_PROVIDER=unisender) ---
# Регистрация: https://go.unisender.ru/
# API-ключ: Кабинет → Настройки → API. Регион (go1 / go2 / b1) — в URL,
# при необходимости поменять можно через UNISENDER_API_URL.
UNISENDER_API_KEY=PUT_UNISENDER_API_KEY
# UNISENDER_API_URL=https://go1.unisender.ru/ru/transactional/api/v1/email/send.json

# --- SendPulse (если EMAIL_PROVIDER=sendpulse) ---
# Регистрация: https://sendpulse.com/ru
# Кабинет → Настройки аккаунта → API: Client ID и Secret
SENDPULSE_CLIENT_ID=PUT_SENDPULSE_CLIENT_ID
SENDPULSE_CLIENT_SECRET=PUT_SENDPULSE_CLIENT_SECRET
